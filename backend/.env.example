# =============================================================================
# Google OAuth 2.0 Credentials
# Obtain from: GCP Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# GCP Configuration
# GCP_API_KEY: API key for Cloud Text-to-Speech REST endpoint
# GCP_PROJECT_ID: Your Google Cloud project ID
# GCP_REGION: Vertex AI region (default: us-central1)
# Note: Vertex AI uses Application Default Credentials (ADC) automatically
# Run: gcloud auth application-default login
# =============================================================================
GCP_API_KEY=your-gcp-api-key-for-cloud-tts
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# =============================================================================
# Firestore Configuration
# FIRESTORE_PROJECT_ID: Project ID for Firestore (defaults to GCP_PROJECT_ID if empty)
# FIRESTORE_DATABASE: Firestore database name (use '(default)' for the default database)
# =============================================================================
FIRESTORE_PROJECT_ID=your-gcp-project-id
FIRESTORE_DATABASE=(default)

# =============================================================================
# Server Settings
# =============================================================================
HOST=0.0.0.0
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# =============================================================================
# Scheduler Settings
# SCHEDULER_API_KEY: API key for authenticating scheduler webhook calls
# NUDGE_INTERVAL_MINUTES: How often (in minutes) to send proactive nudges
# =============================================================================
SCHEDULER_API_KEY=your-scheduler-api-key
NUDGE_INTERVAL_MINUTES=15

# =============================================================================
# MCP Server Paths
# Relative paths from the backend directory to MCP server entry points
# =============================================================================
MCP_CALENDAR_PATH=../mcp-servers/google-calendar/server.py
MCP_TASKS_PATH=../mcp-servers/google-tasks/server.py
MCP_GMAIL_PATH=../mcp-servers/gmail/server.py
